<resources>

	<!--
		Base application theme for API 35+ (Android 15+).
		Edge-to-edge display is enforced on Android 15+, so we explicitly set
		transparent system bars to opt into the behavior cleanly.
		The activity applies WindowInsets to handle content padding.
	-->
	<style name="AppBaseTheme" parent="android:Theme.Material">
		<item name="android:navigationBarColor">@android:color/transparent</item>
		<item name="android:statusBarColor">@android:color/transparent</item>
	</style>

</resources>
